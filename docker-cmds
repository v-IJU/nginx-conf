# Rebuild without cache
docker build --no-cache -t server-app:latest .

# Verify migrations are in image
docker run --rm server-app:latest ls -la prisma/migrations/

# Should show migration files now ✅

  # Commit .dockerignore fix
git add .dockerignore
git commit -m "fix: include prisma migrations in docker build"
git push origin development

# Or manually push image
docker tag server-app:latest registry.gitlab.com/production-erp/server:{branch}
docker push registry.gitlab.com/production-erp/server:{branch}

